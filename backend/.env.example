PORT=3002

# --- Local development (recommended) ---
# Install PostgreSQL locally, create database "shopsweet", then use:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/shopsweet
# DB_SSL=false

# --- Remote Render PostgreSQL (must use EXTERNAL URL, not Internal) ---
# Render Dashboard → your Postgres → Connect → External Database URL
# DATABASE_URL=postgresql://user:pass@dpg-xxxxx-a.REGION-postgres.render.com/shopsweet

DATABASE_URL=postgresql://postgres:password@localhost:5432/shopsweet
DB_SSL=false

JWT_SECRET=your_jwt_secret

FRONTEND_URL=https://shopsweet.vercel.app

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your-gmail-username@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=ShopSweet <no-reply@shopsweet.com>
# SMTP_REPLY_TO=support@shopsweet.com
# SMTP_ADMIN_EMAIL=your-gmail-username@gmail.com
# SMTP_SECURE=true